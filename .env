# ═══════════════════════════════════════════════════════════
#  GitFix AI — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit the real .env file to GitHub.
# ═══════════════════════════════════════════════════════════

# ── Groq (Free LLM API) ───────────────────────────────────
# Get this from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_key_here

# ── GitHub ────────────────────────────────────────────────
# Create a PAT at: GitHub → Settings → Developer Settings → Tokens
# Required scopes: repo (full), workflow
GITHUB_PAT=ghp_your_token_here

# ── Paths (used internally by the app) ───────────────────
# Where cloned repositories will be stored on your machine
REPOS_CLONE_PATH=./cloned_repos

# Where ChromaDB will persist its vector embeddings
CHROMA_DB_PATH=./chroma_store

# ── App Settings ─────────────────────────────────────────
LOG_LEVEL=INFO

# Groq model to use — llama-3.3-70b-versatile is best for code
LLM_MODEL=llama-3.3-70b-versatile

# Max number of retry attempts when tests fail
MAX_RETRIES=3
